<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile — Heelstivate</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include('../partials/navbar') %>

  <div class="container py-5">
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4">
          <img src="<%= user.Profile && user.Profile.avatarUrl ? user.Profile.avatarUrl : 'https://placehold.co/120x120?text=👤' %>"
            class="rounded-circle mx-auto mb-3" width="120" height="120" style="object-fit:cover;">
          <h5 class="fw-bold"><%= user.username %></h5>
          <p class="text-muted"><%= user.email %></p>
          <span class="badge bg-dark text-capitalize"><%= user.role %></span>
          <% if (user.Profile && user.Profile.phoneNumber) { %>
            <p class="text-muted mt-2 mb-0">📞 <%= user.Profile.phoneNumber %></p>
          <% } %>
          <% if (user.Profile && user.Profile.address) { %>
            <p class="text-muted mb-0">📍 <%= user.Profile.address %></p>
          <% } %>
        </div>
      </div>

      <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4">
          <h5 class="fw-bold mb-4">✏️ Edit Profile</h5>
          <form action="/profile/update" method="POST">
            <div class="mb-3">
              <label class="form-label fw-semibold">Alamat</label>
              <input type="text" name="address" class="form-control"
                value="<%= user.Profile && user.Profile.address ? user.Profile.address : '' %>"
                placeholder="Alamat lengkap">
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">Nomor HP</label>
              <input type="text" name="phoneNumber" class="form-control"
                value="<%= user.Profile && user.Profile.phoneNumber ? user.Profile.phoneNumber : '' %>"
                placeholder="08xxxxxxxxxx">
            </div>
            <div class="mb-4">
              <label class="form-label fw-semibold">URL Avatar</label>
              <input type="url" name="avatarUrl" class="form-control"
                value="<%= user.Profile && user.Profile.avatarUrl ? user.Profile.avatarUrl : '' %>"
                placeholder="https://...">
            </div>
            <button type="submit" class="btn btn-dark px-4">Simpan Perubahan</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
