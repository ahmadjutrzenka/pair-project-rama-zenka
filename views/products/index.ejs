<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products — Heelstivate</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .product-card { transition: transform 0.2s ease; }
    .product-card:hover { transform: translateY(-4px); box-shadow: 0 8px 20px rgba(0,0,0,0.1) !important; }
    .product-img { height: 220px; object-fit: cover; }
  </style>
</head>
<body class="bg-light">
  <%- include('../partials/navbar') %>

  <div class="container py-5">
    <h2 class="fw-bold mb-4">All Products</h2>

    <!-- Search & Filter -->
    <form action="/products" method="GET" class="mb-4">
      <div class="row g-2">
        <div class="col-md-4">
          <input type="text" name="search" class="form-control"
            placeholder="Cari sepatu..." value="<%= search %>">
        </div>
        <div class="col-md-3">
          <select name="categoryId" class="form-select">
            <option value="">Semua Kategori</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat.id %>" <%= categoryId == cat.id ? 'selected' : '' %>>
                <%= cat.name %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <select name="sort" class="form-select">
            <option value="">Sort by</option>
            <option value="price_asc" <%= sort == 'price_asc' ? 'selected' : '' %>>Harga: Termurah</option>
            <option value="price_desc" <%= sort == 'price_desc' ? 'selected' : '' %>>Harga: Termahal</option>
            <option value="terlaris" <%= sort == 'terlaris' ? 'selected' : '' %>>Terlaris</option>
          </select>
        </div>
        <div class="col-md-1">
          <button type="submit" class="btn btn-dark w-100">Cari</button>
        </div>
        <div class="col-md-1">
          <a href="/products" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
      </div>
    </form>

    <!-- Product Grid -->
    <% if (products.length == 0) { %>
      <div class="text-center py-5">
        <p class="text-muted fs-5">Produk tidak ditemukan 😔</p>
        <a href="/products" class="btn btn-outline-dark">Lihat Semua</a>
      </div>
    <% } else { %>
      <div class="row g-4">
        <% products.forEach(function(product) { %>
          <div class="col-md-4 col-sm-6">
            <div class="card h-100 border-0 shadow-sm product-card">
              <div class="position-relative">
                <img src="<%= product.imgUrl || 'https://placehold.co/400x220?text=No+Image' %>"
                  class="card-img-top product-img" alt="<%= product.name %>">
                <% if (product.isBestSeller()) { %>
                  <span class="position-absolute top-0 start-0 badge bg-warning text-dark m-2">🔥 Terlaris</span>
                <% } %>
              </div>
              <div class="card-body">
                <% if (product.Category) { %>
                  <span class="badge bg-dark mb-2"><%= product.Category.name %></span>
                <% } %>
                <h6 class="card-title fw-bold"><%= product.name %></h6>
                <p class="fw-semibold mb-1"><%= product.formatPrice() %></p>
                <p class="text-muted small mb-0">Stok: <%= product.stock %> | Terjual: <%= product.sold %></p>
              </div>
              <div class="card-footer bg-white border-0 d-flex gap-2">
                <a href="/products/<%= product.id %>" class="btn btn-outline-dark btn-sm w-100">Detail</a>
                <% if (session && session.role == 'seller' && session.userId == product.userId) { %>
                  <a href="/products/<%= product.id %>/edit" class="btn btn-warning btn-sm w-100">Edit</a>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
