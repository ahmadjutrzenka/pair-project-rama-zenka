<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> — Heelstivate</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include('../partials/navbar') %>

  <div class="container py-5">
    <div class="row g-4">
      <div class="col-md-5">
        <img src="<%= product.imgUrl || 'https://placehold.co/500x400?text=No+Image' %>"
          class="img-fluid rounded shadow w-100" style="max-height:400px;object-fit:cover;" alt="<%= product.name %>">
      </div>
      <div class="col-md-7">
        <% if (product.Category) { %>
          <span class="badge bg-dark mb-2"><%= product.Category.name %></span>
        <% } %>
        <% if (product.isBestSeller()) { %>
          <span class="badge bg-warning text-dark mb-2">🔥 Terlaris</span>
        <% } %>
        <h2 class="fw-bold mt-1"><%= product.name %></h2>
        <h4 class="fw-semibold mb-3"><%= product.formatPrice() %></h4>
        <p class="text-muted"><%= product.description %></p>
        <p class="mb-1"><strong>Stok:</strong> <%= product.stock %></p>
        <p class="mb-2"><strong>Ukuran:</strong> EU <%= product.size %></p>
        <p class="mb-1"><strong>Terjual:</strong> <%= product.sold %> pasang</p>
        <p class="mb-4"><strong>Seller:</strong> <%= product.User ? product.User.username : '-' %></p>

        <% if (session && session.role == 'buyer') { %>
          <% if (product.stock > 0) { %>
            <form action="/cart/<%= product.id %>" method="POST" class="d-flex gap-2 align-items-center mb-3">
              <input type="number" name="quantity" class="form-control" style="width:90px"
                value="1" min="1" max="<%= product.stock %>">
              <button type="submit" class="btn btn-dark px-4">🛒 Tambah ke Cart</button>
            </form>
          <% } else { %>
            <button class="btn btn-secondary px-4 mb-3" disabled>Stok Habis</button>
          <% } %>
        <% } %>

        <% if (session && session.role == 'seller' && session.userId == product.userId) { %>
          <div class="d-flex gap-2 mb-3">
            <a href="/products/<%= product.id %>/edit" class="btn btn-warning">✏️ Edit</a>
            <form action="/products/<%= product.id %>/delete" method="POST">
              <button type="submit" class="btn btn-danger"
                onclick="return confirm('Yakin mau hapus produk ini?')">🗑️ Hapus</button>
            </form>
          </div>
        <% } %>

        <a href="/products" class="btn btn-outline-dark">← Kembali</a>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
