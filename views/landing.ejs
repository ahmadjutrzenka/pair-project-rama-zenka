<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Heelstivate — Toko Sepatu Online</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .hero {
      background: #1a1a1a;
      min-height: 100vh;
      display: flex;
      align-items: center;
    }
    .feature-card:hover {
      transform: translateY(-5px);
      transition: all 0.3s ease;
    }
  </style>
</head>
<body>
  <section class="hero text-white">
    <div class="container text-center">
      <h1 class="display-3 fw-bold mb-3">👟 Heelstivate</h1>
      <p class="lead mb-4 fs-5">Temukan sepatu terbaik untuk setiap gaya hidupmu.</p>
      <div class="d-flex justify-content-center gap-3">
        <a href="/products" class="btn btn-light btn-lg px-4 fw-semibold">Shop Now</a>
        <a href="/register" class="btn btn-outline-light btn-lg px-4">Daftar Sekarang</a>
      </div>
    </div>
  </section>

  <section class="py-5 bg-white">
    <div class="container">
      <h2 class="text-center fw-bold mb-5">Kategori Sepatu</h2>
      <div class="row g-4 text-center">
        <div class="col-md-3">
          <div class="card border-0 shadow-sm p-4 feature-card h-100">
            <div class="display-4 mb-3">🏃</div>
            <h5 class="fw-bold">Sports</h5>
            <p class="text-muted small">Running, Football, Basketball</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 shadow-sm p-4 feature-card h-100">
            <div class="display-4 mb-3">👟</div>
            <h5 class="fw-bold">Casual</h5>
            <p class="text-muted small">Sneakers, Canvas</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 shadow-sm p-4 feature-card h-100">
            <div class="display-4 mb-3">👔</div>
            <h5 class="fw-bold">Formal</h5>
            <p class="text-muted small">Boots, Loafers, Oxford</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 shadow-sm p-4 feature-card h-100">
            <div class="display-4 mb-3">👠</div>
            <h5 class="fw-bold">Womenswear</h5>
            <p class="text-muted small">Heels, Flatshoes, Sandals</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-5 bg-dark text-white text-center">
    <div class="container">
      <h3 class="fw-bold mb-3">Siap tampil percaya diri?</h3>
      <a href="/register" class="btn btn-light btn-lg px-5">Mulai Belanja</a>
    </div>
  </section>

  <%- include('./partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
