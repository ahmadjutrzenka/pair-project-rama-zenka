<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tambah Produk — Hellstivate</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include('../partials/navbar') %>

  <div class="container py-5">
    <div class="card border-0 shadow-sm p-4 mx-auto" style="max-width:600px;">
      <h4 class="fw-bold mb-4">➕ Tambah Produk Baru</h4>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form action="/products" method="POST">
        <div class="mb-3">
          <label class="form-label fw-semibold">Nama Produk</label>
          <input type="text" name="name" class="form-control" placeholder="Nama sepatu" required>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Deskripsi</label>
          <textarea name="description" class="form-control" rows="3" placeholder="Deskripsi produk" required></textarea>
        </div>
        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Harga (Rp)</label>
            <input type="number" name="price" class="form-control" placeholder="Min. 1000" min="1000" required>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Stok</label>
            <input type="number" name="stock" class="form-control" placeholder="Jumlah stok" min="0" required>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">URL Gambar</label>
          <input type="url" name="imgUrl" class="form-control" placeholder="https://...">
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Kategori</label>
          <select name="categoryId" class="form-select" required>
            <option value="" disabled selected>Pilih kategori</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-dark px-4">Simpan Produk</button>
          <a href="/products" class="btn btn-outline-secondary">Batal</a>
        </div>
      </form>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
